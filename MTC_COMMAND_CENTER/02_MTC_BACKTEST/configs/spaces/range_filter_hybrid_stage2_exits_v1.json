{
  "random": {
    "stop_loss.use_sl": { "dist": "choice", "values": [true, false] },
    "stop_loss.mode": { "dist": "choice", "values": ["ATR", "%", "Swing+ATR"] },
    "stop_loss.atr_len": { "dist": "uniform_int", "low": 10, "high": 28 },
    "stop_loss.atr_mult": { "dist": "uniform_float", "low": 1.0, "high": 5.0, "step": 0.25 },
    "stop_loss.percent": { "dist": "uniform_float", "low": 0.4, "high": 2.0, "step": 0.1 },
    "stop_loss.swing_basis": { "dist": "choice", "values": ["Wick", "Body"] },
    "stop_loss.swing_lookback": { "dist": "uniform_int", "low": 5, "high": 30 },
    "stop_loss.swing_atr_len": { "dist": "uniform_int", "low": 7, "high": 21 },
    "stop_loss.swing_atr_mult": { "dist": "uniform_float", "low": 0.0, "high": 1.5, "step": 0.1 },

    "take_profit.use_tp": { "dist": "choice", "values": [true, false] },
    "take_profit.mode": { "dist": "choice", "values": ["R", "ATR", "%"] },
    "take_profit.rr": { "dist": "uniform_float", "low": 0.8, "high": 4.0, "step": 0.2 },
    "take_profit.atr_len": { "dist": "uniform_int", "low": 10, "high": 28 },
    "take_profit.atr_mult": { "dist": "uniform_float", "low": 1.0, "high": 5.0, "step": 0.25 },
    "take_profit.percent": { "dist": "uniform_float", "low": 0.5, "high": 4.0, "step": 0.25 },

    "break_even.use_break_even": { "dist": "choice", "values": [false, true] },
    "break_even.rr": { "dist": "uniform_float", "low": 0.5, "high": 2.5, "step": 0.1 },
    "break_even.buffer_r": { "dist": "uniform_float", "low": 0.0, "high": 0.5, "step": 0.05 },

    "trailing.use_trailing": { "dist": "choice", "values": [false, true] },
    "trailing.atr_len": { "dist": "uniform_int", "low": 10, "high": 28 },
    "trailing.start_r": { "dist": "uniform_float", "low": 0.5, "high": 3.5, "step": 0.25 },
    "trailing.dist_r": { "dist": "uniform_float", "low": 0.5, "high": 3.5, "step": 0.25 },

    "time_stop.enabled": { "dist": "choice", "values": [false, true] },
    "time_stop.use_bars": { "dist": "choice", "values": [false, true] },
    "time_stop.bars": { "dist": "choice", "values": [20, 35, 50, 75, 100] },
    "time_stop.condition": { "dist": "choice", "values": ["Always", "Profit Only", "Loss Only"] }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.mcc/schemas/dashboard_config.schema.json",
  "title": "MCC Dashboard Config",
  "type": "object",
  "required": ["schema_version", "app_name", "mode", "live_trading_enabled", "dry_run", "enabled_tabs"],
  "properties": {
    "schema_version": { "type": "string" },
    "app_name": { "type": "string" },
    "short_name": { "type": "string" },
    "mode": { "type": "string" },
    "live_trading_enabled": { "type": "boolean" },
    "dry_run": { "type": "boolean" },
    "default_timezone": { "type": "string" },
    "refresh_seconds": { "type": "integer" },
    "enabled_tabs": { "type": "array", "items": { "type": "string" } },
    "render_markdown_reports": { "type": "boolean" }
  },
  "additionalProperties": false
}

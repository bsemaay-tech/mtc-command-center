{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MTC Multi-Oracle Parity Manifest",
  "type": "object",
  "required": [
    "manifest_id",
    "cases"
  ],
  "properties": {
    "manifest_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "engines": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "baseline": {
      "type": "string"
    },
    "levels": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
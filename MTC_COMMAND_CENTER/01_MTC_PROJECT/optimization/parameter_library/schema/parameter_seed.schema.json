{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MTC V2 Parameter Seed",
  "type": "object",
  "required": [
    "strategy_id",
    "producer_id",
    "asset",
    "timeframe",
    "rank",
    "parameter_set_id",
    "parameter_hash",
    "source_run_id",
    "source_report_path",
    "dataset_ids",
    "source_type_summary",
    "params",
    "metrics",
    "warnings",
    "status"
  ],
  "properties": {
    "strategy_id": {
      "type": "string"
    },
    "producer_id": {
      "type": "string"
    },
    "asset": {
      "type": "string"
    },
    "timeframe": {
      "type": "string"
    },
    "rank": {
      "type": "integer",
      "minimum": 1
    },
    "parameter_set_id": {
      "type": "string"
    },
    "parameter_hash": {
      "type": "string"
    },
    "source_run_id": {
      "type": "string"
    },
    "source_report_path": {
      "type": "string"
    },
    "dataset_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_type_summary": {
      "type": [
        "string",
        "object"
      ]
    },
    "params": {
      "type": "object"
    },
    "metrics": {
      "type": "object"
    },
    "walkforward_consistency": {
      "type": [
        "number",
        "null"
      ]
    },
    "positive_symbol_count": {
      "type": [
        "integer",
        "null"
      ]
    },
    "positive_timeframe_count": {
      "type": [
        "integer",
        "null"
      ]
    },
    "regime_summary": {
      "type": [
        "object",
        "string",
        "null"
      ]
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
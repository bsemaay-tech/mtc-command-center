{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MTC V2 Per-Asset/Timeframe Seed Output",
  "description": "Research seed only; not Pine default; not production parameter.",
  "type": "object",
  "required": [
    "strategy_id",
    "producer_id",
    "asset",
    "symbol",
    "timeframe",
    "rank",
    "parameter_set_id",
    "parameter_hash",
    "source_run_id",
    "source_output_path",
    "dataset_ids",
    "source_type_summary",
    "st_factor",
    "global_atr_length",
    "sl_atr_mult",
    "tp_mode",
    "tp_r_multiple",
    "risk_long",
    "risk_short",
    "train_net_profit_pct",
    "validation_net_profit_pct",
    "test_net_profit_pct",
    "profit_factor",
    "max_drawdown_pct",
    "win_rate",
    "trade_count",
    "walkforward_consistency",
    "positive_window_ratio",
    "regime_summary",
    "regime_warning",
    "status",
    "confidence",
    "notes"
  ],
  "properties": {
    "strategy_id": { "type": "string" },
    "producer_id": { "type": "string" },
    "asset": { "type": "string" },
    "symbol": { "type": "string" },
    "timeframe": { "type": "string" },
    "rank": { "type": "integer", "minimum": 1 },
    "parameter_set_id": { "type": "string" },
    "parameter_hash": { "type": "string" },
    "source_run_id": { "type": "string" },
    "source_output_path": { "type": "string" },
    "dataset_ids": { "type": "string" },
    "source_type_summary": { "type": "string" },
    "st_factor": { "type": ["number", "string", "null"] },
    "global_atr_length": { "type": ["number", "integer", "string", "null"] },
    "sl_atr_mult": { "type": ["number", "string", "null"] },
    "tp_mode": { "type": ["string", "null"] },
    "tp_r_multiple": { "type": ["number", "string", "null"] },
    "risk_long": { "type": ["number", "string", "null"] },
    "risk_short": { "type": ["number", "string", "null"] },
    "train_net_profit_pct": { "type": ["number", "string", "null"] },
    "validation_net_profit_pct": { "type": ["number", "string", "null"] },
    "test_net_profit_pct": { "type": ["number", "string", "null"] },
    "profit_factor": { "type": ["number", "string", "null"] },
    "max_drawdown_pct": { "type": ["number", "string", "null"] },
    "win_rate": { "type": ["number", "string", "null"] },
    "trade_count": { "type": ["integer", "number", "string", "null"] },
    "walkforward_consistency": { "type": ["number", "string", "null"] },
    "positive_window_ratio": { "type": ["number", "string", "null"] },
    "regime_summary": { "type": ["string", "object", "null"] },
    "regime_warning": { "type": ["string", "null"] },
    "status": {
      "type": "string",
      "enum": ["RESEARCH_SEED", "MEDIUM_SEED", "STRICT_SEED", "REJECTED", "INSUFFICIENT_DATA", "SMOKE_RESEARCH_SEED"]
    },
    "confidence": {
      "type": "string",
      "enum": ["LOW", "MEDIUM", "HIGH"]
    },
    "notes": { "type": "string" }
  },
  "additionalProperties": true
}
